DB_CLOUD_URI=mongodb+srv://<USERNAME>:<PASSWORD>@peerprep-grp8.wu6qj3s.mongodb.net/user_service_db?appName=Peerprep-Grp8
DB_LOCAL_URI=mongodb://127.0.0.1:27017/peerprepUserServiceDB
PORT=3001

# Will use cloud MongoDB Atlas database
ENV=PROD

# Secret for creating JWT signature
JWT_SECRET=<SECRET KEY>

# SMTP configuration for OTP email verification 
# Example values below are for Gmail with an App Password.
# For Gmail: enable 2FA and generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com